# Environment variables consumed by clap (see `--help`).
# Uncomment and adjust if your board mapping differs from defaults.
#
# NANOHAT_I2C_BUS=/dev/i2c-0
# NANOHAT_I2C_ADDR=0x3c
# NANOHAT_GPIO_CHIP=/dev/gpiochip1
# NANOHAT_K1_LINE=0
# NANOHAT_K2_LINE=2
# NANOHAT_K3_LINE=3
# NANOHAT_LOG_FILE=/tmp/nanohat-oled.log
# NANOHAT_PID_FILE=/run/nanohat-oled.pid
# NANOHAT_SPLASH_SECS=2
# NANOHAT_SHUTDOWN_MSG_SECS=2
# NANOHAT_SHUTDOWN_WAIT_SECS=1
# NANOHAT_IDLE_POWER_OFF_SECS=30
